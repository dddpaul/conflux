{
  "manifest_version": 3,
  "name": "Conflux",
  "version": "0.1.0",
  "description": "Export Confluence pages as Markdown",
  "permissions": ["activeTab", "downloads", "storage"],
  "host_permissions": [],
  "optional_host_permissions": ["https://*/"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Conflux"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
